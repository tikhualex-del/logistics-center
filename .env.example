# Docker Compose environment variables
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=logistics_center

# Backend runtime variables
DATABASE_URL="postgresql://postgres:password@localhost:5433/logistics_center?schema=public"
REDIS_URL="redis://localhost:6379"
JWT_SECRET="change-me-access-secret"
JWT_REFRESH_SECRET="change-me-refresh-secret"
ROUTING_PROVIDER_MODE=auto
YANDEX_MAPS_API_KEY=
YANDEX_ROUTING_API_KEY=
YANDEX_ROUTING_BASE_URL="https://api.routing.yandex.net/v2/route"
YANDEX_GEOCODER_BASE_URL="https://geocode-maps.yandex.ru/1.x/"
