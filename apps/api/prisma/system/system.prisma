generator client {
  provider = "prisma-client"
  output   = "../../src/generated/prisma-system"
}

datasource db {
  provider = "postgresql"
  schemas  = ["system"]
}

// ─── Platform root entity ────────────────────────────────────────────────────
// Company is a platform-level (system schema) entity.
// All tenant data lives in a separate per-company schema: tenant_<company_id>.

model Company {
  id              String   @id @default(uuid())
  name            String
  slug            String   @unique
  status          String   // active | trial | inactive | suspended | pending_setup | archived
  timezone        String
  defaultCurrency String
  language        String
  country         String
  contactEmail    String
  contactPhone    String
  planId          String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  impersonationSessions PlatformImpersonationSession[]
  integrations          Integration[]

  @@schema("system")
}

// ─── Platform operator ────────────────────────────────────────────────────────
// Separate identity from tenant users. Not stored in any tenant schema.

model PlatformSuperAdmin {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  status       String   // active | suspended
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  impersonationSessions PlatformImpersonationSession[]

  @@schema("system")
}

// ─── Super admin impersonation audit ─────────────────────────────────────────
// Append-only. Written when super admin enters a company context.

model PlatformImpersonationSession {
  id              String    @id @default(uuid())
  superAdminId    String
  targetCompanyId String
  startedAt       DateTime  @default(now())
  endedAt         DateTime?
  reason          String?

  superAdmin PlatformSuperAdmin @relation(fields: [superAdminId], references: [id])
  company    Company            @relation(fields: [targetCompanyId], references: [id])

  @@index([superAdminId])
  @@index([targetCompanyId])
  @@schema("system")
}

// ─── Integrations ─────────────────────────────────────────────────────────────
// One integration per externalSource per company.
// Lives in system schema so API key lookup can resolve company before tenant context.
// externalSource: stable, immutable channel key (e.g. "shopify-main", "wms-central").
// apiKeyHash: SHA-256 of raw key — fast lookup, no bcrypt slowness needed for API keys.

model Integration {
  id              String   @id @default(uuid())
  companyId       String
  name            String
  externalSource  String   // immutable after creation
  status          String   // active | inactive
  apiKeyHash      String   @unique  // SHA-256(rawKey)
  apiKeyPrefix    String   // first 8 chars of random part, for display only
  createdByUserId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])

  @@unique([companyId, externalSource])
  @@index([companyId])
  @@schema("system")
}

// ─── Platform-level audit ─────────────────────────────────────────────────────
// Append-only. Tracks super admin and system-level actions.
// actorId: PlatformSuperAdmin.id when actorType = 'super_admin', null for system

model PlatformAuditEvent {
  id         String   @id @default(uuid())
  actorType  String   // super_admin | system
  actorId    String?
  action     String
  targetType String?
  targetId   String?
  companyId  String?  // which company was affected, if any
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([actorId, createdAt])
  @@index([targetType, targetId])
  @@index([companyId, createdAt])
  @@schema("system")
}
