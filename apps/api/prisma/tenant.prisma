// ─── Tenant schema definition ─────────────────────────────────────────────────
// This file defines the structure of per-company tenant schemas.
//
// IMPORTANT: No @@schema annotations here.
// These models use unqualified table names and rely on PostgreSQL search_path
// being set to the correct tenant schema (tenant_<company_id>) at connection time.
// Schema resolution is handled by getTenantPrisma() in src/lib/prisma-tenant.ts.
//
// Used for:
//   - prisma generate → type-safe TenantPrismaClient
//   - prisma migrate diff → generates tenant-schema.sql for provisioning
//
// Never run prisma migrate dev on this file directly.
// Tenant schemas are created via TenantProvisioningService, not prisma migrate.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma-tenant"
}

datasource db {
  provider = "postgresql"
}

// ─── Users ───────────────────────────────────────────────────────────────────
// Tenant user — lives in the company's tenant schema.
// companyId is denormalized here for query convenience even though we're
// already inside the correct tenant schema.

model User {
  id           String    @id @default(uuid())
  companyId    String    // denormalized — matches the tenant's company
  email        String    @unique
  fullName     String
  passwordHash String
  status       String    // active | invited | suspended | removed
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  roleLinks UserRoleLink[]
  sessions  UserSession[]

  @@index([companyId])
  @@index([email])
}

// ─── Roles ───────────────────────────────────────────────────────────────────
// System-defined roles. Seeded during tenant provisioning.
// Not created or modified via API in MVP.
// name values: owner | dispatcher | viewer

model Role {
  id       String  @id @default(uuid())
  name     String  @unique
  label    String
  isSystem Boolean @default(true)

  userRoleLinks UserRoleLink[]
}

// ─── User–Role link ───────────────────────────────────────────────────────────
// Replaces CompanyMembership from the old public schema.
// One user → one active role per tenant (enforced at app level, not unique constraint,
// to allow graceful role transitions).

model UserRoleLink {
  id        String   @id @default(uuid())
  userId    String
  roleId    String
  status    String   // active | invited | suspended | removed
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id])

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
}

// ─── User sessions ────────────────────────────────────────────────────────────
// Append-only on login. Revoked by setting revokedAt on logout.
// jwtId = jti claim in the JWT — used to verify the session is still active.

model UserSession {
  id        String    @id @default(uuid())
  userId    String
  companyId String
  jwtId     String    @unique
  issuedAt  DateTime  @default(now())
  expiresAt DateTime
  revokedAt DateTime?
  userAgent String?
  ipAddress String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([jwtId])
}

// ─── Audit: general event log ─────────────────────────────────────────────────
// Replaces AuditLog from the old public schema.
// Append-only. No FK to User intentionally — audit must survive user deletion,
// and actorId may also refer to a super admin (not a tenant user).

model AuditEvent {
  id         String   @id @default(uuid())
  companyId  String
  actorType  String   // user | system | super_admin
  actorId    String?
  actorLabel String?
  entityType String
  entityId   String?
  action     String
  sessionId  String?
  ipAddress  String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([companyId, createdAt])
  @@index([entityType, entityId])
  @@index([action, createdAt])
}

// ─── Audit: entity snapshots ──────────────────────────────────────────────────
// Point-in-time JSON snapshot of an entity, taken when a critical change occurs.
// triggeredBy: AuditEvent.id that caused this snapshot.

model AuditEntitySnapshot {
  id           String   @id @default(uuid())
  companyId    String
  entityType   String
  entityId     String
  snapshotData Json
  takenAt      DateTime @default(now())
  triggeredBy  String?

  @@index([entityType, entityId])
  @@index([companyId, takenAt])
}

// ─── Audit: access events ────────────────────────────────────────────────────
// Tracks authentication and authorization events.
// No FK to User — must survive user deletion, and some events pre-date user lookup.

model AuditAccessEvent {
  id        String   @id @default(uuid())
  companyId String
  userId    String?
  sessionId String?
  action    String   // login | logout | access_denied | token_refresh
  resource  String?
  ipAddress String?
  createdAt DateTime @default(now())

  @@index([companyId, createdAt])
  @@index([userId])
}

// ─── Audit: manual overrides ──────────────────────────────────────────────────
// Written when a super admin acts within a tenant context.

model AuditOverrideEvent {
  id           String   @id @default(uuid())
  companyId    String
  superAdminId String?
  userId       String
  overrideType String
  reason       String
  createdAt    DateTime @default(now())

  @@index([companyId, createdAt])
}

// ─── Couriers ─────────────────────────────────────────────────────────────────
// MVP model — Wave 2. No GPS, no vehicle type, no availability windows.
// status: active | inactive

model Courier {
  id        String   @id @default(uuid())
  companyId String   // denormalized — matches the tenant's company
  name      String
  phone     String
  status    String   // active | inactive
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders Order[]

  @@index([companyId])
  @@index([status])
  @@index([companyId, status])
}

// ─── Orders ───────────────────────────────────────────────────────────────────
// Canonical Order model per Operational Core Contract (Wave 2).
// status: new | assigned | picked_up | delivered | cancelled | failed
// source: manual | integration

model Order {
  id              String    @id @default(uuid())
  companyId       String    // denormalized — matches the tenant's company

  // Source tracking
  source          String    // manual | integration
  externalId      String?   // set only for integration-created orders
  externalSource  String?   // integration name/slug, e.g. 'shopify'

  // State machine
  status          String    // new | assigned | picked_up | delivered | cancelled | failed
  courierId       String?   // null until assigned; non-null iff status in {assigned, picked_up}

  // Customer and addresses
  customerName    String
  customerPhone   String
  pickupAddress   String
  deliveryAddress String
  pickupLat       Float?
  pickupLng       Float?
  deliveryLat     Float?
  deliveryLng     Float?

  // Scheduling
  scheduledPickupAt DateTime?
  deadline          DateTime?

  // Notes
  notes           String?

  // Outcome context
  cancelReason    String?   // optional on cancel
  failureReason   String?   // required on fail (enforced at app level)

  // Authorship — null for integration-created orders
  createdByUserId String?

  // State timestamps
  assignedAt      DateTime?
  pickedUpAt      DateTime?
  deliveredAt     DateTime?
  cancelledAt     DateTime?
  failedAt        DateTime?

  // Record timestamps
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  courier       Courier?             @relation(fields: [courierId], references: [id])
  statusHistory OrderStatusHistory[]
  routeOrder    RouteOrder?

  // Integration dedup key — PostgreSQL NULL semantics: only enforced when both
  // externalSource and externalId are non-null (NULL != NULL in UNIQUE constraint).
  // Idempotent duplicate semantics deferred to integrations wave.
  @@unique([companyId, externalSource, externalId])

  @@index([companyId])
  @@index([status])
  @@index([courierId])
  @@index([companyId, status])
  @@index([companyId, courierId])
}

// ─── Routes ───────────────────────────────────────────────────────────────────
// A Route groups multiple orders into a single courier run.
// status: draft | assigned | completed | cancelled
// RouteOrder is active membership only — rows are deleted when membership ends
// (remove, cancel, complete). Historical context lives in OrderStatusHistory.

model Route {
  id              String    @id @default(uuid())
  companyId       String    // denormalized
  courierId       String?   // null until assigned
  status          String    // draft | assigned | completed | cancelled
  scheduledDate   String?   // YYYY-MM-DD — intended delivery date, optional
  notes           String?
  createdByUserId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  routeOrders RouteOrder[]

  @@index([companyId])
  @@index([status])
  @@index([courierId])
  @@index([companyId, status])
}

// Active membership only. Deleted when order leaves the route (any reason).
// @@unique([orderId]) enforces one active route per order at DB level.
// Sequence positions are always contiguous 1..N within a route.

model RouteOrder {
  id        String   @id @default(uuid())
  routeId   String
  orderId   String   @unique  // one active route per order
  sequence  Int

  createdAt DateTime @default(now())

  route Route @relation(fields: [routeId], references: [id], onDelete: Cascade)
  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([routeId, sequence])
  @@index([routeId])
}

// ─── Integration inbound log ──────────────────────────────────────────────────
// Append-only. One entry per inbound request, regardless of outcome.
// rawPayload is always stored for traceability.
// status: success | duplicate | invalid | error

model IntegrationInboundLog {
  id            String   @id @default(uuid())
  integrationId String   // system.Integration.id — no FK (cross-schema)
  companyId     String   // denormalized
  rawPayload    Json
  externalId    String?  // extracted from payload before validation
  status        String   // success | duplicate | invalid | error
  orderId       String?  // null unless success or duplicate
  errorMessage  String?  // null unless invalid or error

  createdAt DateTime @default(now())

  @@index([integrationId, createdAt])
  @@index([orderId])
  @@index([companyId, createdAt])
}

// ─── Order status history ─────────────────────────────────────────────────────
// Append-only. Written on every state-changing operation including
// order creation, status transitions, and assignment changes.

model OrderStatusHistory {
  id         String   @id @default(uuid())
  orderId    String
  fromStatus String?  // null for the creation event
  toStatus   String
  actorType  String   // user | integration | system
  actorId    String?  // userId or integration id; null for system
  reason     String?  // populated for cancel, fail, and reassign operations
  createdAt  DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([orderId, createdAt])
}
