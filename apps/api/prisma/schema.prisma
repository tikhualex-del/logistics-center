// ─── Public schema — legacy operational models ────────────────────────────────
// Order and Courier are temporarily here until Wave 2 moves them to tenant schemas.
//
// Company moved to system schema (prisma/system/system.prisma).
// User/Role/Session/Audit moved to per-tenant schemas (prisma/tenant.prisma).
//
// companyId on Order and Courier is a plain String — no FK constraint.
// Cross-schema FK enforcement is handled at the application level.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── WAVE 2: Will move to tenant schema ───────────────────────────────────────

model Order {
  id                String   @id @default(uuid())
  companyId         String   // references system.Company — no FK (cross-schema)
  courierId         String?
  externalId        String?
  sourceType        String   @default("manual")
  isManuallyTouched Boolean  @default(false)
  status            String
  deliveryDate      String?
  address           String
  lat               Float?
  lng               Float?
  comment           String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  courier Courier? @relation(fields: [courierId], references: [id], onDelete: SetNull)

  @@unique([companyId, externalId])
  @@index([companyId])
  @@index([status])
  @@index([deliveryDate])
  @@index([courierId])
  @@index([companyId, courierId])
  @@index([companyId, deliveryDate])
}

model Courier {
  id             String    @id @default(uuid())
  companyId      String    // references system.Company — no FK (cross-schema)
  firstName      String
  lastName       String
  phone          String
  status         String
  transportType  String
  lat            Float?
  lng            Float?
  lastLocationAt DateTime?
  locationSource String?
  trackingStatus String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  orders Order[]

  @@index([companyId])
  @@index([status])
  @@index([companyId, status])
}

// ─── DEPRECATED: Replaced by AuditEvent in tenant schema ─────────────────────
// Kept temporarily so existing audit-log.service.ts continues to compile.
// Will be removed when audit module is migrated in Wave 1.
// companyId is plain String — no FK to system.Company.

model AuditLog {
  id         String   @id @default(uuid())
  companyId  String   // references system.Company — no FK (cross-schema)
  actorType  String
  actorId    String?
  actorLabel String?
  entityType String
  entityId   String?
  action     String
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([companyId, createdAt])
  @@index([entityType, entityId])
  @@index([action, createdAt])
}
