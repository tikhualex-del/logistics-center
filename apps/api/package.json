{
  "name": "api",
  "version": "1.0.0",
  "description": "Logistics Center API",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "build": "tsc",
    "start": "node dist/main.js",
    "generate": "prisma generate --schema prisma/schema.prisma && prisma generate --schema prisma/system/system.prisma && prisma generate --schema prisma/tenant.prisma",
    "migrate:public": "prisma migrate dev --schema prisma/schema.prisma",
    "migrate:system": "prisma migrate dev --schema prisma/system/system.prisma"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.0",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.20.0",
    "prisma": "^7.6.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.5.2",
    "@types/pg": "^8.20.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^6.0.2"
  }
}
