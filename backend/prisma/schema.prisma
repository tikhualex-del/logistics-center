generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Company {
  id                     String                 @id @default(uuid())
  name                   String
  created_at             DateTime               @default(now())
  updated_at             DateTime               @updatedAt
  audit_logs             AuditLog[]
  company_features       CompanyFeature[]
  couriers               Courier[]
  dispatchers            Dispatcher[]
  external_id_maps       ExternalIdMap[]
  integration_events     IntegrationEvent[]
  integrations           Integration[]
  order_status_history   OrderStatusHistory[]
  orders                 Order[]
  payment_recalculations PaymentRecalculation[]
  payment_rule_versions  PaymentRuleVersion[]
  payments               Payment[]
  route_points           RoutePoint[]
  routes                 Route[]
  users                  User[]
  zones                  Zone[]

  @@map("companies")
}

model User {
  id                           String                 @id @default(uuid())
  company_id                   String
  role                         UserRole
  email                        String
  phone                        String?
  first_name                   String
  last_name                    String?
  password_hash                String?
  is_active                    Boolean                @default(true)
  last_login_at                DateTime?
  created_at                   DateTime               @default(now())
  updated_at                   DateTime               @updatedAt
  audit_entries                AuditLog[]             @relation("AuditActor")
  updated_company_features     CompanyFeature[]       @relation("CompanyFeaturesUpdatedBy")
  courier                      Courier?
  dispatcher                   Dispatcher?
  processed_integration_events IntegrationEvent[]     @relation("IntegrationEventsProcessedBy")
  created_integrations         Integration[]          @relation("IntegrationsCreatedBy")
  order_status_changes         OrderStatusHistory[]   @relation("OrderStatusChangedBy")
  assigned_orders              Order[]                @relation("OrdersAssignedBy")
  created_orders               Order[]                @relation("OrdersCreatedBy")
  payment_recalculations       PaymentRecalculation[] @relation("PaymentRecalculationsTriggeredBy")
  payment_rule_changes         PaymentRuleVersion[]   @relation("PaymentRulesChangedBy")
  payment_approvals            Payment[]              @relation("PaymentsApprovedBy")
  created_routes               Route[]                @relation("RoutesCreatedBy")
  company                      Company                @relation(fields: [company_id], references: [id])

  @@unique([company_id, email])
  @@index([company_id, role])
  @@index([company_id, is_active])
  @@map("users")
}

model Courier {
  id                     String                 @id @default(uuid())
  company_id             String
  user_id                String                 @unique
  status                 CourierStatus          @default(offline)
  latitude               Decimal?               @db.Decimal(10, 7)
  longitude              Decimal?               @db.Decimal(10, 7)
  last_seen_at           DateTime?
  metadata               Json?
  created_at             DateTime               @default(now())
  updated_at             DateTime               @updatedAt
  company                Company                @relation(fields: [company_id], references: [id])
  user                   User                   @relation(fields: [user_id], references: [id])
  orders                 Order[]                @relation("OrdersCourier")
  payment_recalculations PaymentRecalculation[]
  payments               Payment[]
  routes                 Route[]

  @@index([company_id, status])
  @@index([company_id, user_id])
  @@map("couriers")
}

model Dispatcher {
  id         String   @id @default(uuid())
  company_id String
  user_id    String   @unique
  is_active  Boolean  @default(true)
  metadata   Json?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  company    Company  @relation(fields: [company_id], references: [id])
  user       User     @relation(fields: [user_id], references: [id])

  @@index([company_id, is_active])
  @@map("dispatchers")
}

model Zone {
  id         String   @id @default(uuid())
  company_id String
  name       String
  color      String?
  polygon    Json
  base_rate  Decimal? @db.Decimal(12, 2)
  is_active  Boolean  @default(true)
  metadata   Json?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  orders     Order[]
  company    Company  @relation(fields: [company_id], references: [id])

  @@unique([company_id, name])
  @@index([company_id, is_active])
  @@map("zones")
}

model Order {
  id                  String               @id @default(uuid())
  company_id          String
  zone_id             String?
  status              OrderStatus          @default(new)
  external_id         String?
  order_number        String?
  customer_name       String?
  customer_phone      String?
  delivery_address    String
  delivery_latitude   Decimal?             @db.Decimal(10, 7)
  delivery_longitude  Decimal?             @db.Decimal(10, 7)
  comment             String?
  scheduled_date      DateTime?
  time_window_from    DateTime?
  time_window_to      DateTime?
  assigned_courier_id String?
  created_by_user_id  String?
  assigned_by_user_id String?
  metadata            Json?
  created_at          DateTime             @default(now())
  updated_at          DateTime             @updatedAt
  status_history      OrderStatusHistory[]
  assigned_by         User?                @relation("OrdersAssignedBy", fields: [assigned_by_user_id], references: [id])
  assigned_courier    Courier?             @relation("OrdersCourier", fields: [assigned_courier_id], references: [id])
  company             Company              @relation(fields: [company_id], references: [id])
  created_by          User?                @relation("OrdersCreatedBy", fields: [created_by_user_id], references: [id])
  zone                Zone?                @relation(fields: [zone_id], references: [id])
  route_points        RoutePoint[]

  @@unique([company_id, external_id])
  @@unique([company_id, order_number])
  @@index([company_id, status])
  @@index([company_id, zone_id])
  @@index([company_id, assigned_courier_id])
  @@index([company_id, scheduled_date])
  @@map("orders")
}

model OrderStatusHistory {
  id                 String       @id @default(uuid())
  company_id         String
  order_id           String
  from_status        OrderStatus?
  to_status          OrderStatus
  changed_by_user_id String?
  reason             String?
  metadata           Json?
  created_at         DateTime     @default(now())
  updated_at         DateTime     @updatedAt
  changed_by         User?        @relation("OrderStatusChangedBy", fields: [changed_by_user_id], references: [id])
  company            Company      @relation(fields: [company_id], references: [id])
  order              Order        @relation(fields: [order_id], references: [id])

  @@index([company_id, order_id, created_at])
  @@index([company_id, to_status])
  @@map("order_status_history")
}

model Route {
  id                 String       @id @default(uuid())
  company_id         String
  courier_id         String?
  status             RouteStatus  @default(draft)
  version            Int          @default(1)
  route_date         DateTime
  created_by_user_id String?
  optimization_data  Json?
  deleted_at         DateTime?
  metadata           Json?
  created_at         DateTime     @default(now())
  updated_at         DateTime     @updatedAt
  route_points       RoutePoint[]
  company            Company      @relation(fields: [company_id], references: [id])
  courier            Courier?     @relation(fields: [courier_id], references: [id])
  created_by         User?        @relation("RoutesCreatedBy", fields: [created_by_user_id], references: [id])

  @@index([company_id, status])
  @@index([company_id, route_date])
  @@index([company_id, deleted_at])
  @@map("routes")
}

model RoutePoint {
  id          String    @id @default(uuid())
  company_id  String
  route_id    String
  order_id    String
  sequence    Int
  planned_eta DateTime?
  actual_eta  DateTime?
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt
  company     Company   @relation(fields: [company_id], references: [id])
  order       Order     @relation(fields: [order_id], references: [id])
  route       Route     @relation(fields: [route_id], references: [id])

  @@unique([route_id, sequence])
  @@unique([route_id, order_id])
  @@index([company_id, route_id])
  @@map("route_points")
}

model PaymentRuleVersion {
  id                 String          @id @default(uuid())
  company_id         String
  rule_key           String
  name               String
  rule_type          PaymentRuleType
  version            Int
  config             Json
  changed_by_user_id String?
  change_reason      String?
  is_active          Boolean         @default(true)
  effective_from     DateTime?
  effective_to       DateTime?
  created_at         DateTime        @default(now())
  updated_at         DateTime        @updatedAt
  changed_by         User?           @relation("PaymentRulesChangedBy", fields: [changed_by_user_id], references: [id])
  company            Company         @relation(fields: [company_id], references: [id])
  payments           Payment[]

  @@unique([company_id, rule_key, version])
  @@index([company_id, rule_type, is_active])
  @@map("payment_rule_versions")
}

model Payment {
  id                      String                 @id @default(uuid())
  company_id              String
  courier_id              String
  payment_rule_version_id String?
  status                  PaymentStatus          @default(draft)
  period_start            DateTime
  period_end              DateTime
  currency                String                 @default("RUB")
  amount                  Decimal                @db.Decimal(12, 2)
  breakdown               Json
  approved_by_user_id     String?
  approved_at             DateTime?
  paid_at                 DateTime?
  metadata                Json?
  created_at              DateTime               @default(now())
  updated_at              DateTime               @updatedAt
  recalculations          PaymentRecalculation[]
  approved_by             User?                  @relation("PaymentsApprovedBy", fields: [approved_by_user_id], references: [id])
  company                 Company                @relation(fields: [company_id], references: [id])
  courier                 Courier                @relation(fields: [courier_id], references: [id])
  payment_rule_version    PaymentRuleVersion?    @relation(fields: [payment_rule_version_id], references: [id])

  @@index([company_id, courier_id, status])
  @@index([company_id, period_start, period_end])
  @@map("payments")
}

model PaymentRecalculation {
  id                   String   @id @default(uuid())
  company_id           String
  payment_id           String
  courier_id           String
  previous_amount      Decimal? @db.Decimal(12, 2)
  recalculated_amount  Decimal  @db.Decimal(12, 2)
  reason               String
  triggered_by_user_id String?
  breakdown            Json?
  created_at           DateTime @default(now())
  updated_at           DateTime @updatedAt
  company              Company  @relation(fields: [company_id], references: [id])
  courier              Courier  @relation(fields: [courier_id], references: [id])
  payment              Payment  @relation(fields: [payment_id], references: [id])
  triggered_by         User?    @relation("PaymentRecalculationsTriggeredBy", fields: [triggered_by_user_id], references: [id])

  @@index([company_id, payment_id, created_at])
  @@map("payment_recalculations")
}

model AuditLog {
  id          String          @id @default(uuid())
  company_id  String
  actor_id    String?
  actor_role  AuditActorRole?
  action      String
  entity_type String
  entity_id   String
  before      Json?
  after       Json?
  request_id  String?
  metadata    Json?
  created_at  DateTime        @default(now())
  updated_at  DateTime        @updatedAt
  actor       User?           @relation("AuditActor", fields: [actor_id], references: [id])
  company     Company         @relation(fields: [company_id], references: [id])

  @@index([company_id, entity_type, entity_id])
  @@index([company_id, action, created_at])
  @@map("audit_logs")
}

model Integration {
  id                   String             @id @default(uuid())
  company_id           String
  name                 String
  provider             String
  is_active            Boolean            @default(true)
  base_url             String?
  inbound_secret       String?
  outbound_webhook_url String?
  webhook_secret       String?
  settings             Json?
  created_by_user_id   String?
  created_at           DateTime           @default(now())
  updated_at           DateTime           @updatedAt
  external_id_maps     ExternalIdMap[]
  integration_events   IntegrationEvent[]
  company              Company            @relation(fields: [company_id], references: [id])
  created_by           User?              @relation("IntegrationsCreatedBy", fields: [created_by_user_id], references: [id])

  @@unique([company_id, name])
  @@index([company_id, provider, is_active])
  @@map("integrations")
}

model ExternalIdMap {
  id             String       @id @default(uuid())
  company_id     String
  integration_id String?
  entity_type    String
  external_id    String
  internal_id    String
  metadata       Json?
  created_at     DateTime     @default(now())
  updated_at     DateTime     @updatedAt
  company        Company      @relation(fields: [company_id], references: [id])
  integration    Integration? @relation(fields: [integration_id], references: [id])

  @@unique([company_id, entity_type, external_id])
  @@index([company_id, entity_type, internal_id])
  @@index([company_id, integration_id])
  @@map("external_id_map")
}

model IntegrationEvent {
  id                   String                 @id @default(uuid())
  company_id           String
  integration_id       String?
  direction            IntegrationDirection
  event_type           String
  entity_type          String?
  entity_id            String?
  idempotency_key      String?
  external_id          String?
  signature            String?
  status               IntegrationEventStatus @default(pending)
  attempts             Int                    @default(0)
  next_retry_at        DateTime?
  processed_at         DateTime?
  payload              Json
  response             Json?
  processed_by_user_id String?
  created_at           DateTime               @default(now())
  updated_at           DateTime               @updatedAt
  company              Company                @relation(fields: [company_id], references: [id])
  integration          Integration?           @relation(fields: [integration_id], references: [id])
  processed_by         User?                  @relation("IntegrationEventsProcessedBy", fields: [processed_by_user_id], references: [id])

  @@index([company_id, status, next_retry_at])
  @@index([company_id, idempotency_key])
  @@unique([company_id, direction, event_type, idempotency_key])
  @@map("integration_events")
}

model CompanyFeature {
  id                 String    @id @default(uuid())
  company_id         String
  feature_key        String
  enabled            Boolean   @default(false)
  config             Json?
  updated_by_user_id String?
  enabled_at         DateTime?
  disabled_at        DateTime?
  created_at         DateTime  @default(now())
  updated_at         DateTime  @updatedAt
  company            Company   @relation(fields: [company_id], references: [id])
  updated_by         User?     @relation("CompanyFeaturesUpdatedBy", fields: [updated_by_user_id], references: [id])

  @@unique([company_id, feature_key])
  @@index([company_id, enabled])
  @@map("company_features")
}

enum UserRole {
  admin
  dispatcher
  courier
}

enum CourierStatus {
  inactive
  available
  busy
  offline
  suspended
}

enum OrderStatus {
  new
  confirmed
  assigned
  handed_over
  in_transit
  delivered
  undelivered
  returned
  cancelled
}

enum RouteStatus {
  draft
  planned
  in_progress
  completed
  cancelled
}

enum PaymentStatus {
  draft
  calculated
  approved
  paid
  disputed
}

enum PaymentRuleType {
  zone_rate
  per_km
  per_order
  bonus
  penalty
  minimum_guarantee
}

enum IntegrationDirection {
  inbound
  outbound
}

enum IntegrationEventStatus {
  pending
  processing
  succeeded
  failed
  retrying
}

enum AuditActorRole {
  admin
  dispatcher
  courier
  system
}
